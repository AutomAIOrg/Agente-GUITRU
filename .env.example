# Database configuration (recommended)
DB_HOST=localhost
DB_USER=your_user
DB_PASS=your_password
DB_NAME=your_database_test
DB_PORT=3306

# Compatibility aliases (optional)
# Use only if your environment already provides MYSQL_* names.
MYSQL_HOST=localhost
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database_test
MYSQL_PORT=3306

# Electric Allowance
ELECTRIC=

