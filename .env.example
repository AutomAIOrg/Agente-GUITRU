# --- Database ---
DB_HOST=localhost
DB_USER=your_user
DB_PASS=your_password
DB_NAME=your_database_test
DB_PORT=3306

# Database configuration for Docker-Compose
MYSQL_USER=user_test
MYSQL_PASSWORD=pass_test
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=db_test

# --- Electric allowance ---
ELECTRIC=

# --- OpenAI ---
LLM_OPENAI_API_KEY=""
LLM_OPENAI_MODEL="gpt-5-mini-2025-08-07"
LLM_OPENAI_TIMEOUT_SECONDS=30

# --- Agent ---
AGENT_MAX_ITERATIONS=2
AGENT_MAX_STEPS=8

# --- Google Calendar ---
GCAL_CALENDAR_ID="primary"
GCAL_TIMEZONE="Europe/Madrid"
GCAL_SEND_UPDATES="none"
GCAL_OAUTH_CLIENT_ID=""
GCAL_OAUTH_CLIENT_SECRET=""
GCAL_OAUTH_REFRESH_TOKEN=""
GCAL_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token

# --- Whatsapp ---
WA_PHONE_NUMBER_ID=""
WA_WABA_ID=""
WA_ACCESS_TOKEN=""
WA_VERIFY_TOKEN=""
META_APP_SECRET=""
META_GRAPH_VERSION=v22.0
